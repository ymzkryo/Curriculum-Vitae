    "textlint-filter-rule-comments": "^1.3.0",
    "textlint-filter-rule-whitelist": "^2.0.0",
    "textlint-rule-abbr-within-parentheses": "^1.0.2",
    "textlint-rule-footnote-order": "^1.0.3",
